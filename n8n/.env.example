COMPOSE_PROJECT_NAME=mystudyspace_n8n
N8N_VERSION=stable
TZ=Region/City
# Set to a writable path for your platform (Linux/macOS/Windows), for example ./n8n-data
N8N_DATA_ROOT=./n8n-data

# Local bind and public URL values.
# For production behind HTTPS/reverse proxy:
# - set N8N_PROTOCOL=https
# - set N8N_HOST=n8n.yourdomain.com
# - set WEBHOOK_URL=https://n8n.yourdomain.com/
# - set N8N_EDITOR_BASE_URL=https://n8n.yourdomain.com
# - set N8N_SECURE_COOKIE=true
N8N_BIND_ADDRESS=127.0.0.1
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_HOST=localhost
WEBHOOK_URL=http://localhost:5678/
N8N_EDITOR_BASE_URL=http://localhost:5678
N8N_SECURE_COOKIE=false

N8N_BASIC_AUTH_USER=admin
# N8N_BASIC_AUTH_PASSWORD should be a strong random secret (at least 32 bytes), generated with a cryptographically secure tool.
# Do not reuse other secrets. Example: openssl rand -base64 32
# Example (Node): node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Store securely (secret manager/CI secret store) and never commit real values.
N8N_BASIC_AUTH_PASSWORD=change_this_basic_auth_password
# N8N_ENCRYPTION_KEY must be a 64-character hex string (32 random bytes, hex-encoded).
# Generate with OpenSSL: openssl rand -hex 32
# Generate with Node: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Store securely (secret manager/CI secret store) and never commit real values.
N8N_ENCRYPTION_KEY=replace_with_64_char_hex_string

POSTGRES_DB=n8n
POSTGRES_USER=n8n
# POSTGRES_PASSWORD should be a strong random secret (at least 32 bytes), generated with a cryptographically secure tool.
# Do not reuse other secrets. Example: openssl rand -base64 32
# Example (Node): node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Store securely (secret manager/CI secret store) and never commit real values.
POSTGRES_PASSWORD=change_this_postgres_password
# Required for queue mode, multi-worker scaling, or external/shared Redis usage.
# Can be omitted for very basic single-instance setups that do not use Redis-backed queueing.
# REDIS_PASSWORD should be a strong random secret (at least 32 bytes), generated with a cryptographically secure tool.
# Do not reuse other secrets. Example: openssl rand -base64 32
# Example (Node): node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Store securely (secret manager/CI secret store) and never commit real values.
REDIS_PASSWORD=change_this_redis_password

N8N_WORKER_CONCURRENCY=5
N8N_CONCURRENCY_PRODUCTION_LIMIT=20
N8N_LOG_LEVEL=info

# Internal auth for backend /api/internal/ocr/* routes (required).
# Expected format: hex string, minimum 32 random bytes (64 hex chars).
# Generate (OpenSSL): openssl rand -hex 32
# Generate (Node): node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Store securely (secret manager/CI secret store) and never commit real values.
# Runtime behavior: if both INTERNAL_API_KEY and OCR_INTERNAL_API_KEY are empty,
# backend internal OCR routes are effectively disabled and return auth/config errors.
INTERNAL_API_KEY=change_this_internal_api_key
# Legacy alias for backend fallback logic.
# Backend resolves key as: INTERNAL_API_KEY first, then OCR_INTERNAL_API_KEY only if INTERNAL_API_KEY is empty.
# Recommended default: set OCR_INTERNAL_API_KEY to the same value as INTERNAL_API_KEY during migration.
# Deprecation note: planned removal of OCR_INTERNAL_API_KEY fallback after 2026-09-30.
OCR_INTERNAL_API_KEY=change_this_internal_api_key
