COMPOSE_PROJECT_NAME=mystudyspace_n8n
N8N_VERSION=stable
TZ=Asia/Kolkata
N8N_DATA_ROOT=D:/DockerData/mystudyspace-n8n

# Local bind and public URL values.
# For production behind HTTPS/reverse proxy:
# - set N8N_PROTOCOL=https
# - set N8N_HOST=n8n.yourdomain.com
# - set WEBHOOK_URL=https://n8n.yourdomain.com/
# - set N8N_EDITOR_BASE_URL=https://n8n.yourdomain.com
# - set N8N_SECURE_COOKIE=true
N8N_BIND_ADDRESS=127.0.0.1
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_HOST=localhost
WEBHOOK_URL=http://localhost:5678/
N8N_EDITOR_BASE_URL=http://localhost:5678
N8N_SECURE_COOKIE=false

N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_this_basic_auth_password
N8N_ENCRYPTION_KEY=replace_with_64_char_random_key

POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change_this_postgres_password

N8N_WORKER_CONCURRENCY=5
N8N_CONCURRENCY_PRODUCTION_LIMIT=20
N8N_LOG_LEVEL=info
