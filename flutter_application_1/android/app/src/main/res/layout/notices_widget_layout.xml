<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/widget_notice_board_background"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_chip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/widget_notice_tape_background"
            android:paddingStart="10dp"
            android:paddingTop="6dp"
            android:paddingEnd="10dp"
            android:paddingBottom="6dp"
            android:text="@string/widget_chip_label_notices"
            android:textAllCaps="true"
            android:textColor="@color/widget_notice_chip_text"
            android:textSize="@dimen/widget_chip_text_size"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_hint"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:text="@string/widget_hint_open"
            android:textColor="@color/widget_notice_hint_text"
            android:textSize="@dimen/widget_hint_text_size"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="@string/widget_title_campus_notices"
        android:textColor="@color/widget_notice_heading_text"
        android:textSize="@dimen/widget_title_text_size"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:text="@string/widget_subtitle_notices_default"
        android:textColor="@color/widget_notice_supporting_text"
        android:textSize="@dimen/widget_subtitle_text_size" />

    <LinearLayout
        android:id="@+id/widget_list_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_item_1"
            style="@style/WidgetNoticeFeatureItem"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_item_2"
            style="@style/WidgetNoticeItem"
            android:layout_marginTop="10dp" />

        <TextView
            android:id="@+id/widget_item_3"
            style="@style/WidgetNoticeItem"
            android:layout_marginTop="8dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_empty_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/widget_notice_paper_background"
        android:gravity="center"
        android:paddingStart="14dp"
        android:paddingTop="18dp"
        android:paddingEnd="14dp"
        android:paddingBottom="18dp"
        android:text="@string/widget_empty_notices"
        android:textColor="@color/widget_notice_supporting_text"
        android:textSize="@dimen/widget_item_text_size"
        android:visibility="gone" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="end"
        android:text="@string/widget_hint_open"
        android:textColor="@color/widget_notice_hint_text"
        android:textSize="11sp"
        android:textStyle="bold" />
</LinearLayout>
