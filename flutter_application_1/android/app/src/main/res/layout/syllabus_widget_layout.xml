<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/widget_schedule_shell_background"
    android:orientation="vertical"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <View
            android:id="@+id/widget_live_dot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/widget_schedule_live_dot" />

        <TextView
            android:id="@+id/widget_chip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/widget_chip_label_syllabus"
            android:textAllCaps="true"
            android:textColor="@color/widget_schedule_live_accent"
            android:textSize="13sp"
            android:letterSpacing="0.08"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_hint"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:text="@string/widget_hint_expand"
            android:textColor="@color/widget_schedule_hint_text"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_location_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="@string/widget_subtitle_syllabus_default"
        android:textColor="@color/widget_subtitle_text_color"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="@string/widget_title_syllabus"
        android:textColor="@color/widget_title_text_color"
        android:textSize="34sp"
        android:textStyle="bold" />

    <StackView
        android:id="@+id/widget_stack"
        android:layout_width="match_parent"
        android:layout_height="194dp"
        android:layout_marginTop="20dp"
        android:animateFirstView="false"
        android:loopViews="false" />

    <TextView
        android:id="@+id/widget_empty_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/widget_schedule_card_background"
        android:gravity="center_vertical"
        android:minHeight="156dp"
        android:paddingStart="18dp"
        android:paddingTop="20dp"
        android:paddingEnd="18dp"
        android:paddingBottom="20dp"
        android:text="@string/widget_empty_syllabus"
        android:textColor="@color/widget_subtitle_text_color"
        android:textSize="14sp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/widget_footer_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/widget_indicator_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:id="@+id/widget_indicator_primary"
                android:layout_width="18dp"
                android:layout_height="4dp"
                android:background="@drawable/widget_schedule_indicator_active" />

            <View
                android:id="@+id/widget_indicator_secondary"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/widget_schedule_indicator_inactive" />

            <View
                android:id="@+id/widget_indicator_tertiary"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/widget_schedule_indicator_inactive" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_swipe_hint"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:gravity="end"
            android:text="@string/widget_hint_swipe"
            android:textAllCaps="true"
            android:textColor="@color/widget_schedule_hint_text"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
